{
  "manifest_version": 3,
  "name": "Lowballer",
  "description": "Estimate a lowball offer with a dynamic acceptance probability.",
  "version": "0.1.0",
  "action": {
    "default_title": "Lowballer",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "*://grailed.com/*",
    "*://*.grailed.com/*",
    "*://depop.com/*",
    "*://*.depop.com/*",
    "*://etsy.com/*",
    "*://*.etsy.com/*",
    "*://ebay.com/*",
    "*://www.ebay.com/*",
    "*://*.ebay.com/*",
    "*://facebook.com/marketplace/*",
    "*://www.facebook.com/marketplace/*",
    "*://m.facebook.com/marketplace/*",
    "*://*.facebook.com/marketplace/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://grailed.com/*",
        "*://*.grailed.com/*",
        "*://depop.com/*",
        "*://*.depop.com/*",
        "*://etsy.com/*",
        "*://*.etsy.com/*",
        "*://ebay.com/*",
        "*://www.ebay.com/*",
        "*://*.ebay.com/*",
        "*://facebook.com/marketplace/*",
        "*://www.facebook.com/marketplace/*",
        "*://m.facebook.com/marketplace/*",
        "*://*.facebook.com/marketplace/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
